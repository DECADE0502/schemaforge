    "default_parameters": {
      "v_in": "20",
      "v_out": "5",
      "i_out_max": "1.4",
      "fsw": "500",
      "ic_model": "TPS54202",
      "c_in": "10uF",
      "c_out": "22uF",
      "l_value": "15uH",
      "c_boot": "100nF",
      "v_ref": "0.596",
      "r_fb_upper": "75kΩ",
      "r_fb_lower": "10kΩ",
      "r_fb_total": "85",
      "led_resistor": "1kΩ"
    },
    "sizing_components": [
      {
        "role": "input_cap",
        "value": "10uF",
        "formula": "Cin = Iout * D * (1 - D) / (fsw * ΔVin)",
        "rationale": "按输入纹波电压估算，并设置 10μF 的工程下限。"
      },
      {
        "role": "inductor",
        "value": "15uH",
        "formula": "L = Vout * (1 - D) / (fsw * ΔIL)",
        "rationale": "按 30% 输出电流纹波设计，再圆整到常用电感系列。"
      },
      {
        "role": "output_cap",
        "value": "22uF",
        "formula": "Cout = ΔIL / (8 * fsw * ΔVout)",
        "rationale": "按 1% 输出纹波估算，并设置 22μF 的工程下限。"
      },
      {
        "role": "fb_upper",
        "value": "75kΩ",
        "formula": "Rupper = Rlower * (Vout / Vref - 1)",
        "rationale": "固定下拉电阻 10kΩ，再按反馈参考电压求上拉值。"
      },
      {
        "role": "fb_lower",
        "value": "10kΩ",
        "formula": "Rlower = 10kΩ",
        "rationale": "优先选用稳定、噪声适中的常见阻值作为反馈下拉。"
      }
    ],
    "formulas": [
      {
        "name": "占空比",
        "expression": "D = Vout / Vin",
        "value": "0.25",
        "rationale": "用于估算电感电流纹波与输入电容 RMS 应力。"
      }
    ],
