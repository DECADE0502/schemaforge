    "topology_family": "buck",
    "summary": "TPS54202 的降压设计 recipe，基于典型 Buck 拓扑自动生成外围参数。",
    "pin_roles": {
      "GND": "ground",
      "SW": "switch",
      "VIN": "power_input",
