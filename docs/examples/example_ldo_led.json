{
  "design_name": "5V-3.3V稳压电源（带LED指示）",
  "description": "使用AMS1117-3.3 LDO线性稳压器将5V转为3.3V，并用绿色LED指示电源状态。",
  "modules": [
    {
      "template": "ldo_regulator",
      "instance_name": "main_ldo",
      "parameters": {
        "v_in": "5",
        "v_out": "3.3",
        "c_in": "10μF",
        "c_out": "22μF"
      }
    },
    {
      "template": "led_indicator",
      "instance_name": "power_led",
      "parameters": {
        "v_supply": "3.3",
        "led_color": "green",
        "led_current": "10"
      }
    }
  ],
  "connections": [
    {
      "from_module": "main_ldo",
      "from_net": "VOUT",
      "to_module": "power_led",
      "to_net": "VCC",
      "merged_net_name": "VOUT_3V3"
    },
    {
      "from_module": "main_ldo",
      "from_net": "GND",
      "to_module": "power_led",
      "to_net": "GND",
      "merged_net_name": "GND"
    }
  ],
  "notes": "AMS1117-3.3最大输入电压15V，压差约1.2V。输入电容建议靠近IC放置。LED限流电阻计算：(3.3V-2.2V)/10mA=110Ω，取标准值110Ω。"
}
